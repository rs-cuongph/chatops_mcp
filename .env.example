# ---------------------------------------------------------------------------
# ChatOps connection (required)
# ---------------------------------------------------------------------------

# Base URL of your ChatOps instance (no trailing slash)
CHATOPS_URL=https://chat.runsystem.vn

# Path to the persisted Playwright session file (created by chatops-auth-login)
# Default: .chatops/session.json
CHATOPS_SESSION_FILE=.chatops/session.json

# API path used to validate the session is still alive (default is fine)
CHATOPS_VALIDATE_PATH=/api/v4/users/me

# ---------------------------------------------------------------------------
# Playwright browser for SSO login (optional)
# ---------------------------------------------------------------------------

# Run browser in headless mode (set to "false" so you can complete SSO login)
PLAYWRIGHT_HEADLESS=false

# Browser engine: chromium | firefox | webkit (default: chromium)
PLAYWRIGHT_BROWSER=chromium

# ---------------------------------------------------------------------------
# Logging (optional)
# ---------------------------------------------------------------------------
LOG_LEVEL=info
